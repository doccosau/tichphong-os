{
  "name": "vinext",
  "version": "0.1.0",
  "description": "Run Next.js apps on Vite. Drop-in replacement for the next CLI.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cloudflare/vinext.git"
  },
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "vinext": "dist/cli.js"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./shims/*": {
      "import": "./dist/shims/*.js",
      "types": "./dist/shims/*.d.ts"
    },
    "./server/prod-server": {
      "import": "./dist/server/prod-server.js",
      "types": "./dist/server/prod-server.d.ts"
    },
    "./cloudflare": {
      "import": "./dist/cloudflare/index.js",
      "types": "./dist/cloudflare/index.d.ts"
    },
    "./server/image-optimization": {
      "import": "./dist/server/image-optimization.js",
      "types": "./dist/server/image-optimization.d.ts"
    },
    "./server/app-router-entry": {
      "import": "./dist/server/app-router-entry.js",
      "types": "./dist/server/app-router-entry.d.ts"
    },
    "./config/config-matchers": {
      "import": "./dist/config/config-matchers.js",
      "types": "./dist/config/config-matchers.d.ts"
    },
    "./routing/*": {
      "import": "./dist/routing/*.js",
      "types": "./dist/routing/*.d.ts"
    },
    "./seo": {
      "import": "./dist/seo/index.js",
      "types": "./dist/seo/index.d.ts"
    },
    "./seo/*": {
      "import": "./dist/seo/*.js",
      "types": "./dist/seo/*.d.ts"
    },
    "./pwa": {
      "import": "./dist/pwa/index.js",
      "types": "./dist/pwa/index.d.ts"
    },
    "./server/api-middleware": {
      "import": "./dist/server/api-middleware.js",
      "types": "./dist/server/api-middleware.d.ts"
    },
    "./server/security-headers": {
      "import": "./dist/server/security-headers.js",
      "types": "./dist/server/security-headers.d.ts"
    },
    "./server/rate-limit": {
      "import": "./dist/server/rate-limit.js",
      "types": "./dist/server/rate-limit.d.ts"
    },
    "./admin": {
      "import": "./dist/admin/dashboard-handler.js",
      "types": "./dist/admin/dashboard-handler.d.ts"
    },
    "./utils/logger": {
      "import": "./dist/utils/logger.js",
      "types": "./dist/utils/logger.d.ts"
    },
    "./telemetry": {
      "import": "./dist/telemetry/index.js",
      "types": "./dist/telemetry/index.d.ts"
    },
    "./edge": {
      "import": "./dist/edge/index.js",
      "types": "./dist/edge/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "prepack": "cp ../../README.md README.md && pnpm run build",
    "dev": "tsc --watch"
  },
  "peerDependencies": {
    "react": ">=19.2.0",
    "react-dom": ">=19.2.0",
    "vite": "^7.0.0"
  },
  "dependencies": {
    "@unpic/react": "^1.0.2",
    "@vercel/og": "^0.8.6",
    "@vitejs/plugin-rsc": "^0.5.19",
    "dexie": "^4.3.0",
    "firebase": "^12.10.0",
    "magic-string": "^0.30.21",
    "react-server-dom-webpack": "^19.2.4",
    "rsc-html-stream": "^0.0.7",
    "vite-plugin-commonjs": "^0.10.4",
    "vite-tsconfig-paths": "^6.1.1",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@mdx-js/rollup": "^3.1.1",
    "@types/image-size": "^0.7.0",
    "@types/mdx": "^2.0.13",
    "@types/node": "^25.2.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "image-size": "^2.0.2",
    "vite": "^7.3.1"
  }
}